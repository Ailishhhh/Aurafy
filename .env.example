# Copy to `.env` and fill in. Only EXPO_PUBLIC_* vars are exposed to the app.
#
# Backend proxy that runs the vision model with our secret API key and returns
# the analysis JSON. Leave blank to use the built-in mock analysis (dev mode).
EXPO_PUBLIC_AI_ENDPOINT=

# RevenueCat public SDK key (Android) for in-app subscriptions.
EXPO_PUBLIC_RC_KEY=

# NOTE: The model provider API key (OpenAI/Gemini/etc.) MUST live on the backend
# only. Never put it here or anywhere in the client bundle.
