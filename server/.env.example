# Copy to `.env` (the host/Render dashboard handles this in production).
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the model (default is gemini-2.5-flash, which is on the
# free tier and supports image input). Alternatives: gemini-2.5-flash-lite
# (1,000 free requests/day, lighter quality) or gemini-2.5-pro (higher quality,
# only 100 free/day).
# GEMINI_MODEL=gemini-2.5-flash
