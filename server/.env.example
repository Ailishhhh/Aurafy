# Copy to `.env` (the host/Render dashboard handles this in production).
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Text analysis model (free tier OK). Default: gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# Image model for the "future self" transform.
# NOTE: Gemini IMAGE generation requires BILLING enabled on your key — it is NOT
# on the free tier. /analyze (text) works free; /transform needs billing.
# Default: gemini-3.1-flash-image (current "Nano Banana", ~a few cents/image).
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
