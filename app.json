{
  "expo": {
    "name": "Aurafy",
    "slug": "aurafy",
    "scheme": "aurafy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#07060B",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#07060B",
      "resizeMode": "contain",
      "image": "./assets/splash-icon.png"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.aurafy.app"
    },
    "android": {
      "package": "com.aurafy.app",
      "adaptiveIcon": {
        "backgroundColor": "#07060B",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Aurafy needs access to your photos so you can analyze your selfies and track your glow-up.",
          "cameraPermission": "Aurafy needs camera access so you can scan your face for analysis."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "aiEndpoint": "https://aurafy-myu4.onrender.com/analyze",
      "supabaseUrl": "https://yprlliuxntwlljcvahcr.supabase.co",
      "supabaseAnonKey": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlwcmxsaXV4bnR3bGxqY3ZhaGNyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODI1ODEwMzIsImV4cCI6MjA5ODE1NzAzMn0.cGDoiOfa9lHiCIZNnErCEdAAj_Drezh9cp10t8vs4GY",
      "revenueCatAndroidKey": ""
    }
  }
}
